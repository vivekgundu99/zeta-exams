# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=5000

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/zeta-exams?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Encryption
PHONE_ENCRYPTION_KEY=your_32_character_encryption_key_here

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin Credentials
ADMIN_EMAIL=vivekgundu999@gmail.com

# CloudFront Configuration
CLOUDFRONT_BASE_URL=https://your-cloudfront-domain.cloudfront.net

# Notes:
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. For production, use strong random values for all secrets
# 4. Use rzp_live_ prefix for Razorpay production keys
# 5. Generate strong JWT_SECRET: openssl rand -base64 32
# 6. Generate PHONE_ENCRYPTION_KEY: openssl rand -base64 32